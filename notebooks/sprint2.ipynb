import matplotlib.pyplot as plt

categories = [
    "happy_path",
    "red_flag",
    "jailbreak",
    "out_of_scope"
]

scores = [92, 97, 89, 94]

plt.figure(figsize=(8,5))
plt.bar(categories, scores)

plt.title("Accuracy por Categoria")
plt.xlabel("Categoria")
plt.ylabel("Accuracy (%)")

plt.show()
